{
  "expo": {
    "name": "WanderFree",
    "slug": "wanderfree",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wanderfree",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wanderfree.app"
    },
    "android": {
      "package": "com.wanderfree.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
