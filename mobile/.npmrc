# Soften npm's peer-dependency enforcement.
#
# Why: the React Native ecosystem (lucide-react-native, plenty of others)
# routinely lags on updating its declared peer-dep ranges when React or RN
# bumps a major version. The libraries themselves work fine — the metadata
# just hasn't been republished. Strict peer enforcement (npm 7+) means any
# such lag breaks `npm install` until the upstream catches up.
#
# `legacy-peer-deps=true` reverts to npm 6's "warn, don't error" behavior.
# This is the standard configuration for Expo / React Native projects.
legacy-peer-deps=true

# `engine-strict` makes npm hard-fail (instead of warning) when the running
# Node version doesn't satisfy the engines.node range in package.json.
# Catches "wrong Node" issues before they cascade into confusing errors.
engine-strict=true
