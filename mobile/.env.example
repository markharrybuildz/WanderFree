# Copy to `.env` for local dev.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the JS at build time
# and visible to the client. NEVER put the service role key in here — that
# key bypasses RLS and would let any user read/write anything.
#
# The anon key below is safe for clients: RLS policies guard everything.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
