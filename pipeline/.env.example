# Copy this file to `.env` for local development.
# In CI, these come from GitHub Secrets — see .github/workflows/extract.yml.

# Anthropic API key — Claude API auth.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase project URL, e.g. https://abcdefghijklm.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key. BYPASSES RLS — server-side use only.
# Never ship this to the mobile app. Only used by the pipeline writer.
# Find at https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Optional: override the Claude model used for extraction.
# Default is claude-sonnet-4-6 (good cost/quality balance for this workload).
# WANDERFREE_MODEL=claude-sonnet-4-6
